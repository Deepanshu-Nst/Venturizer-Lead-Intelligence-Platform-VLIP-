# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@host:5432/venturizer
DATABASE_SSL=false

# CORS
CORS_ORIGIN=http://localhost:5173

# Auth
API_KEY=change-this-to-a-secure-key-min-8-chars

# Logging
LOG_LEVEL=info

# Upload
UPLOAD_PATH=./uploads


STORAGE_DRIVER=disk
